DJANGO_SETTINGS_MODULE=core.settings
DEBUG=False
SECRET_KEY=troque-esta-chave-no-render

# Banco de dados
USE_SQLITE=False
DATABASE_URL=postgresql://USUARIO:SENHA@HOST:5432/NOME_DO_BANCO?sslmode=require

# Host e segurança do Render
RENDER_EXTERNAL_HOSTNAME=portfolio-crm.onrender.com
ALLOWED_HOSTS=portfolio-crm.onrender.com
CSRF_TRUSTED_ORIGINS=https://portfolio-crm.onrender.com
USE_X_FORWARDED_HOST=True
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
TENANT_ALLOW_QUERY_OVERRIDE=False
TENANT_ENFORCE_SYSTEM_TENANT=True

# Static files
DISABLE_STATIC_MANIFEST=True

# Cloudinary
CLOUDINARY_STORAGE_CLOUD_NAME=SEU_CLOUDINARY_CLOUD_NAME
CLOUDINARY_STORAGE_API_KEY=SEU_CLOUDINARY_API_KEY
CLOUDINARY_STORAGE_API_SECRET=SEU_CLOUDINARY_API_SECRET

# E-mail opcional
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
DEFAULT_FROM_EMAIL=
EMAIL_SENDER_DOMAIN=example.com

# Google Maps
GOOGLE_MAPS_BROWSER_API_KEY=
GOOGLE_MAPS_MAP_ID=